# ─── Sprint 05 — env vars BETA ───────────────────────────────────────
# Source via `source infra/env/beta.env`. Todo script de scripts/*.sh
# que mute infra debe ser invocado con ENV_FILE apuntando a este file.

# ── GCP project ──────────────────────────────────────────────────────
export PROJECT_ID="vr-portal-fb-beta"
export PROJECT_NUMBER="214382208885"
export ENV="beta"
export REGION="us-central1"

# ── Naming conventions (asimétricas vs prod por historia) ────────────
# Service accounts beta: sa-<svc>-beta  (prod: sa-<svc> sin sufijo)
export SA_SUFFIX="-beta"
# Service names beta: ms-<svc>-api-beta (prod: ms-<svc>-api con o sin -prod)
export SVC_SUFFIX="-beta"
# Image names: en AR los repos son "ms-<svc>" (beta) vs "ms-<svc>-api" (prod)
export MS_IMAGE_SUFFIX=""
# Router image
export ROUTER_IMAGE_NAME="apollo-router"
# Auth-validator image
export AUTH_VALIDATOR_IMAGE_NAME="auth-validator"

# ── VPC + connector (importado a TF S04) ─────────────────────────────
export VPC_NAME="viverent-portal-vpc-beta"
export VPC_CONNECTOR="viverent-conn-beta"
export DEFAULT_VPC_EGRESS="private-ranges-only"
export TICKETS_VPC_EGRESS="all-traffic"
# auth-validator + apollo-router necesitan all-traffic para alcanzar
# servicios ingress=internal (apollo-router, 10 subgrafos) via VPC
# connector. URLs *.run.app son IPs publicas y private-ranges-only
# las saca por internet, donde el target ingress=internal rechaza.
export AUTH_VALIDATOR_VPC_EGRESS="all-traffic"
export ROUTER_VPC_EGRESS="all-traffic"

# ── Cloud SQL ────────────────────────────────────────────────────────
export SQL_INSTANCE="viverent-portal-pg-beta"
export SQL_DB_SUFFIX="_db_beta"

# ── Redis (Memorystore) ──────────────────────────────────────────────
export REDIS_INSTANCE="viverent-portal-redis-beta"

# ── Secrets prefix ───────────────────────────────────────────────────
export SECRET_PREFIX="beta_"

# ── Artifact Registry ────────────────────────────────────────────────
export AR_REPO="services"
export IMAGE_BASE="us-central1-docker.pkg.dev/${PROJECT_ID}/${AR_REPO}"

# ── Pub/Sub ──────────────────────────────────────────────────────────
export PUBSUB_AUDIT_TOPIC="ms-core-cross-audit-log-events-beta"

# ── GCS buckets ──────────────────────────────────────────────────────
export GCS_DOCUMENTS_BUCKET="vr-portal-fb-beta-kyc"
export ATTACHMENT_BUCKET="vr-portal-fb-beta-attachments"

# ── Firebase ─────────────────────────────────────────────────────────
export FIREBASE_PROJECT="vr-portal-fb-beta"
export FIREBASE_API_KEY="AIzaSyAOJHdMvykKYEChAHwD4dK_ymZ_dH-E1Yo"
export FIREBASE_APP_ID="1:214382208885:web:9cb7f3a57c21689469153c"
export FIREBASE_MESSAGING_SENDER_ID="214382208885"
export FIREBASE_AUTH_DOMAIN="vr-portal-fb-beta.firebaseapp.com"
export FIREBASE_STORAGE_BUCKET="vr-portal-fb-beta.firebasestorage.app"
export FIREBASE_HOSTING_AUTH_SITE="app-viverent-beta"
export FIREBASE_HOSTING_BACKOFFICE_SITE="backoffice-viverent-beta"
export FIREBASE_HOSTING_INVESTOR_SITE="inversionistas-beta"

# ── URLs públicas frontend ───────────────────────────────────────────
export AUTH_CENTER_URL="https://app-viverent-beta.web.app"
export BACKOFFICE_URL="https://backoffice-viverent-beta.web.app"
export INVERSIONISTA_URL="https://inversionistas-beta.web.app"

# ── CORS gateway ─────────────────────────────────────────────────────
export CORS_ORIGINS="${AUTH_CENTER_URL},${BACKOFFICE_URL},${INVERSIONISTA_URL}"

# ── Cross-service URLs (Cloud Run *.run.app, accesibles via VPC connector) ──
# Estas URLs las consume el render-cloudrun.sh para inyectarlas como
# env vars en los subgrafos que las necesitan:
#   - ms-tickets requiere MS_IDENTITY_URL + MS_CONTRACTS_URL para resolvers
#     que llaman a otros subgrafos (TicketsScopeContext, contract lookups).
#   - auth-validator requiere APOLLO_ROUTER_URL para forwardear /graphql
#     a Apollo Router (interno) tras validar Firebase token + perms.
#   - auth-validator requiere MS_IDENTITY_URL para resolver caller perms
#     (getCallerPermissions) en cache-miss antes del proxy a Apollo.
# Apollo Router es ingress=internal: el hostname *.run.app resuelve
# correcto desde dentro del VPC connector (no desde browsers externos).
export MS_IDENTITY_URL="https://ms-identity-api-beta-tbnl5rdxwa-uc.a.run.app"
export MS_CONTRACTS_URL="https://ms-contracts-api-beta-tbnl5rdxwa-uc.a.run.app"
export APOLLO_ROUTER_URL="https://apollo-router-beta-tbnl5rdxwa-uc.a.run.app"

# ── Cloud Run defaults (overrides per-svc abajo) ─────────────────────
export DEFAULT_MEMORY="512Mi"
export DEFAULT_CPU="1"
export DEFAULT_MIN_SCALE="0"
export DEFAULT_MAX_SCALE="10"
export DEFAULT_CONCURRENCY="80"
export DEFAULT_TIMEOUT_SECONDS="60"
export DEFAULT_INGRESS="internal"
export DEFAULT_LOG_LEVEL="INFO"
export DEFAULT_AUTH_MODE="internal_headers"
export DEFAULT_DB_POOL_SIZE="5"
export DEFAULT_DB_POOL_MAX_OVERFLOW="10"

# ── Per-service overrides (ms-tickets prod tiene tuning especial; beta
# usa defaults pero las vars se exportan para que template no falle) ──
export TICKETS_TIMEOUT_SECONDS="${DEFAULT_TIMEOUT_SECONDS}"
export TICKETS_MIN_SCALE="${DEFAULT_MIN_SCALE}"
export TICKETS_CONCURRENCY="${DEFAULT_CONCURRENCY}"
# ms-tickets es el unico subgrafo que el browser invoca directo (POST
# /graphql/stream para SSE single-connection). Apollo Router OSS no
# soporta federated subscriptions, por eso bypass router y necesita
# ingress publico. La auth queda cubierta por FirebaseAuthMiddleware
# (Bearer id_token Firebase) + CORSMiddleware con CORS_ORIGINS allowlist.
export TICKETS_INGRESS="all"

# ── auth-validator (gateway público) ─────────────────────────────────
# Ingress=all (browser SPA llega directo). Mounta firebase-service-account
# como volume desde secret beta_firebase_service_account.
export AUTH_VALIDATOR_INGRESS="all"
export AUTH_VALIDATOR_MEMORY="512Mi"

# ── ms-identity portal URL (continueUrl Firebase password reset) ─────
# El dominio DEBE estar en authorizedDomains del proyecto Firebase del
# env. Si no, Identity Toolkit responde UNAUTHORIZED_DOMAIN al generar
# el reset link, el catch amplio en mutations.py:563 swallowea el error
# y el email jamas sale (mutation regresa success=True engañosamente).
# Confirmado 2026-05-12 en beta tras el commit f41daf0 de viverent-auth-ui
# que routeo @viverent.com resets al backend.
export PORTAL_URL_IDENTITY="https://app-viverent-beta.web.app"

# ── Build / git ──────────────────────────────────────────────────────
# REPOS_ROOT es local-only del orchestrator workstation. NO se exporta
# en el mirror vr-devops porque los CI runners tienen workspace path
# distinto (/home/runner/work/<repo>/<repo>) y los workflows reusables
# no necesitan esta variable (cada caller checkoutea su propio repo).
# Si algun script CI requiere REPOS_ROOT, computarlo dinamicamente con
# $GITHUB_WORKSPACE en lugar de hardcodearlo aqui.
# export REPOS_ROOT="/Users/a.a/Desktop/ReposMicroservices/Beta/repos"
