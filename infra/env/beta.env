########################################################################
# Proyecto bajo folder nonprod (922128584306) en org viverent.com.
########################################################################

# variables del proyecto en GCP
export PROJECT_ID="vr-portal-fb-beta"
export PROJECT_NUMBER="214382208885"
export ENV="beta"
export REGION="us-central1"

# Aqui se colocan los sufijos
export SA_SUFFIX="-beta"
export SVC_SUFFIX="-beta"
export MS_IMAGE_SUFFIX="-api"
export ROUTER_IMAGE_NAME="apollo-router"
export AUTH_VALIDATOR_IMAGE_NAME="auth-validator"

# Variables para el VPC
export VPC_NAME="viverent-portal-vpc-beta"
export VPC_CONNECTOR="viverent-conn-beta"
export DEFAULT_VPC_EGRESS="private-ranges-only"
export TICKETS_VPC_EGRESS="all-traffic"
# Estas dos requieren all-traffic para alcanzar servicios internal y poder tener comunicacion bidireccional sincrona
export AUTH_VALIDATOR_VPC_EGRESS="all-traffic"
export ROUTER_VPC_EGRESS="all-traffic"

# change_requests (sprint-17) provisionado en beta (promo 004): BD
# change_requests_db_beta + secreto beta_change_requests_database_url.
export STAGING_DB_ENABLED="true"

# Instancia y sufijo de las DB de beta
export SQL_INSTANCE="viverent-portal-pg-beta"
export SQL_DB_SUFFIX="_db_beta"

# Nombre del redis beta
export REDIS_INSTANCE="viverent-portal-redis-beta"

# Prefijo de los secrets
export SECRET_PREFIX="beta_"

# Este es el repositorio donde cloud run consume las imagenes de Cloud Build
export AR_REPO="services"
export IMAGE_BASE="us-central1-docker.pkg.dev/${PROJECT_ID}/${AR_REPO}"

# Topic Pub/Sub al que ms-core publica eventos de auditoría cross-service
export PUBSUB_AUDIT_TOPIC="ms-core-cross-audit-log-events-beta"

# Variables de las buckets(almacenamiento) para beta
export GCS_DOCUMENTS_BUCKET="vr-portal-fb-beta-kyc"
export ATTACHMENT_BUCKET="vr-portal-fb-beta-attachments"

# Configuracion de la identity de firebase.
# NO son secretos: la seguridad está en Firebase Security Rules
# y Authorized Domains, no en estos valores.
export FIREBASE_PROJECT="vr-portal-fb-beta"
export FIREBASE_API_KEY="AIzaSyAOJHdMvykKYEChAHwD4dK_ymZ_dH-E1Yo"
export FIREBASE_APP_ID="1:214382208885:web:9cb7f3a57c21689469153c"
export FIREBASE_MESSAGING_SENDER_ID="214382208885"
export FIREBASE_AUTH_DOMAIN="vr-portal-fb-beta.firebaseapp.com"
export FIREBASE_STORAGE_BUCKET="vr-portal-fb-beta.firebasestorage.app"
export FIREBASE_HOSTING_AUTH_SITE="app-viverent-beta"
export FIREBASE_HOSTING_BACKOFFICE_SITE="backoffice-viverent-beta"
export FIREBASE_HOSTING_INVESTOR_SITE="inversionistas-beta"

# Urls de los front, vienen tal cual firebase con web.app
export AUTH_CENTER_URL="https://app-viverent-beta.web.app"
export BACKOFFICE_URL="https://backoffice-viverent-beta.web.app"
export INVERSIONISTA_URL="https://inversionistas-beta.web.app"
export PORTAL_URL="${INVERSIONISTA_URL}"
export RESEND_FROM_EMAIL="soporte@portal.viverent.com"

# Allowlist de origins de browser que el auth-validator y ms-tickets aceptan
# para responder requests cross-origin. Sin estos origins listados, el browser
# bloquea la respuesta aunque el server haya respondido OK.
# CORS aplica solo entre browser y backend; comunicación entre microservicios
# NO pasa por CORS (usa auth interna).
export CORS_ORIGINS="${AUTH_CENTER_URL},${BACKOFFICE_URL},${INVERSIONISTA_URL}"

# Urls de los Microservicios para hacer funciones Cross-Service
export MS_IDENTITY_URL="https://ms-identity-api-beta-tbnl5rdxwa-uc.a.run.app"
export MS_CORE_URL="https://ms-core-api-beta-tbnl5rdxwa-uc.a.run.app"
export MS_CONTRACTS_URL="https://ms-contracts-api-beta-tbnl5rdxwa-uc.a.run.app"
export MS_PERSONS_URL="https://ms-persons-api-beta-tbnl5rdxwa-uc.a.run.app"
export APOLLO_ROUTER_URL="https://apollo-router-beta-tbnl5rdxwa-uc.a.run.app"

# Valores por defecto de Cloud Run
export DEFAULT_MEMORY="512Mi"
export DEFAULT_CPU="1"
export DEFAULT_MIN_SCALE="0"
export DEFAULT_MAX_SCALE="10"
export DEFAULT_CONCURRENCY="80"
export DEFAULT_TIMEOUT_SECONDS="60"
export DEFAULT_INGRESS="internal"
export DEFAULT_LOG_LEVEL="INFO"
export DEFAULT_AUTH_MODE="internal_headers"
export DEFAULT_DB_POOL_SIZE="5"
export DEFAULT_DB_POOL_MAX_OVERFLOW="10"

# Si un Cloud Run necesita Sobrescribirse se hace en un bloque siguiente como este para ms-tickets
export TICKETS_TIMEOUT_SECONDS="3600"
export TICKETS_MIN_SCALE="1"
export TICKETS_CONCURRENCY="${DEFAULT_CONCURRENCY}"
# Esta es ALL, porque el browser hace post directo a ms tickets para la suscripcion en tiempo real. Este Bypass es necesario ya que solo
# Apollo Router Enterprise soporta suscripciones federadas.
export TICKETS_INGRESS="all"

# Configs override del auth
export AUTH_VALIDATOR_INGRESS="all"
export AUTH_VALIDATOR_MEMORY="512Mi"

# Sprint 1 hotfix (2026-05-28) — bump router memory/cpu para resistir
# parsing de uploads de attachments base64 (PNG/PDF 5-8 MB JSON body).
# 512Mi causaba OOM/restart; 1Gi + 2 vCPU alineado con prod.
export ROUTER_MEMORY="1Gi"
export ROUTER_CPU="2"

# Warm: evita cold-start latency en servicios critical-path del login
export AUTH_VALIDATOR_MIN_SCALE="1"
export ROUTER_MIN_SCALE="1"
export IDENTITY_MIN_SCALE="1"
export PERSONS_MIN_SCALE="1"

#Variable de la URL de beta para el Log In, debe estar autorizada en firebase para el password reset.
export PORTAL_URL_IDENTITY="https://app-viverent-beta.web.app"

# Router lee esta variable al arrancar y hace polling al Apollo Uplink para
# descargar el supergraph composed del variant @beta. APOLLO_KEY viene del
# secret beta_apollo_key.
export APOLLO_GRAPH_REF="viverent-supergraph@beta"

# Beta expone errores de subgrafo para diagnóstico; prod los redacta.
export APOLLO_INCLUDE_SUBGRAPH_ERRORS="true"
