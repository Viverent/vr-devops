# ─── Sprint 05 — env vars PROD ───────────────────────────────────────
# FREEZE PROD activo S00-S11. Este file SOLO se source-a en operaciones
# read-only (terraform plan, dry-run deploy). Mutaciones a prod NO
# permitidas hasta S12.

# ── GCP project ──────────────────────────────────────────────────────
export PROJECT_ID="vr-portal-fb"
export PROJECT_NUMBER="126856503055"
export ENV="prod"
export REGION="us-central1"

# ── Naming conventions ───────────────────────────────────────────────
